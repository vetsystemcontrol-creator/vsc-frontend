# VSC Frontend (Cloudflare Pages) — routing fix
# Objetivo:
# 1) Evitar "tela preta" quando o menu aponta para /clientes, /animais, etc.
# 2) Reescrever (rewrite 200) /rota -> /rota.html, sem redirect externo.
# 3) Preservar pastas estáticas (assets/modules/vendor) sem interferir.

# Root (ajuste se o seu entrypoint for index.html)
/
  /dashboard.html 200

# Preserve static folders (não transformar em .html)
assets/*
  /assets/:splat 200
modules/*
  /modules/:splat 200
vendor/*
  /vendor/:splat 200

# Se existir estas pastas no seu repo, descomente:
# api/*
#   /api/:splat 200
# images/*
#   /images/:splat 200
# css/*
#   /css/:splat 200
# js/*
#   /js/:splat 200

# HTML routing (regra principal)
# Ex.: /clientes -> /clientes.html
# Ex.: /dashboard -> /dashboard.html
# IMPORTANTE: essa linha deve ficar DEPOIS das exceções acima.
/*
  /:splat.html 200

# Fallback SPA (somente se você tiver index.html e rotas que NÃO são .html)
# Se o seu site não for SPA, pode remover esta linha.
# /*
#   /index.html 200
